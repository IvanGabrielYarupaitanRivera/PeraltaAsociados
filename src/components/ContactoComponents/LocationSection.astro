---
import ContactCard from "../shared/ContactCard.astro";
---

<ContactCard
  id="ubicacion"
  icono="mdi:map-marker"
  titulo="Nuestra Ubicación"
  subtitulo="Visítenos en horario de oficina"
  descripcion="Visite a su abogado especializado en Huancavelica y reciba:"
  beneficios={[
    { text: "Consulta presencial en Huancavelica" },
    { text: "Atención personalizada en oficina" },
    { text: "Revisión física de documentos" },
  ]}
  ctaUrl="https://maps.app.goo.gl/SNb1dv2wx7EoXoKh7"
  ctaLabel="Ver en Google Maps"
  ctaIcono="mdi:map-marker"
  footerText="Horario de atención: L - V | 8:00 AM - 8:00 PM"
  ctaAriaLabel="Ver ubicación del abogado en Huancavelica en Google Maps"
/>
