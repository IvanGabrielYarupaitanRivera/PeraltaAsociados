---
import WhatsAppSection from "./WhatsAppSection.astro";
import EmailSection from "./EmailSection.astro";
import LocationSection from "./LocationSection.astro";
import FacebookSection from "./FacebookSection.astro";
import ChatbotSection from "./ChatbotSection.astro";
import BackgroundPattern from "@components/BackgroundPattern.astro";
import ScrollReveal from "@components/ScrollReveal.astro";
---

<section class="py-20 relative bg-neutral-100" id="formas-de-contacto" aria-label="Formas de contacto">
  <BackgroundPattern variant="subtle" opacity={0.3} />

  <main class="relative z-10">
    <ScrollReveal animation="fade-up" delay={100}>
    <div class="container mx-auto px-4">
      <!-- Encabezado decorativo -->
      <header class="flex items-center gap-4 mb-8">
        <span class="sm:block h-0.5 flex-1 bg-secondary" aria-hidden="true"
        ></span>
        <p
          class="text-secondary font-medium tracking-wide uppercase text-sm whitespace-nowrap"
        >
          Contacte a su Abogado
        </p>
        <span class="sm:block h-0.5 flex-1 bg-secondary" aria-hidden="true"
        ></span>
      </header>

      <!-- Título principal -->
      <header class="text-center max-w-3xl mx-auto mb-16">
        <h2
          class="font-serif text-3xl md:text-4xl lg:text-5xl text-primary font-bold mb-4"
        >
          Abogado en Huancavelica a su Servicio
        </h2>
        <p class="text-gray-600">
          Elija la forma más conveniente de contactar con su abogado en
          Huancavelica. Respuesta inmediata y primera consulta gratuita.
        </p>
      </header>

      <section class="grid md:grid-cols-2 lg:grid-cols-3 gap-8 relative">
        <WhatsAppSection />
        <EmailSection />
        <LocationSection />
        <FacebookSection />
        <ChatbotSection />
      </section>
    </div>
    </ScrollReveal>
  </main>
</section>
