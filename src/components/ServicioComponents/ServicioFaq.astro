---
import BackgroundPattern from "@components/BackgroundPattern.astro";
import ScrollReveal from "@components/ScrollReveal.astro";

interface FaqItem {
  pregunta: string;
  respuesta: string;
}

interface Props {
  faqs: FaqItem[];
}

const { faqs } = Astro.props;

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqs.map((faq: FaqItem) => ({
    "@type": "Question",
    "name": faq.pregunta,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.respuesta
    }
  }))
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} is:inline>
</script>

<section class="py-20 relative bg-neutral-100" aria-label="Preguntas frecuentes">
  <BackgroundPattern variant="subtle" opacity={0.3} />
  <div class="relative z-10">
    <div class="container mx-auto px-4">
      <ScrollReveal animation="fade-up" delay={100}>
        <header class="flex items-center gap-4 mb-12">
          <span class="sm:block h-0.5 flex-1 bg-secondary" aria-hidden="true"></span>
          <p class="text-secondary font-medium tracking-wide uppercase text-sm whitespace-nowrap">Preguntas Frecuentes</p>
          <span class="sm:block h-0.5 flex-1 bg-secondary" aria-hidden="true"></span>
        </header>

        <div class="max-w-3xl mx-auto space-y-4">
          {
            faqs.map((faq) => (
              <div class="bg-white rounded-sm shadow-sm">
                <button
                  class="faq-btn w-full flex items-center justify-between gap-4 px-6 py-5 cursor-pointer text-primary font-serif font-bold text-lg hover:bg-primary/5 transition-colors duration-300 text-left"
                  aria-expanded="false"
                >
                  <span class="text-pretty pr-4">{faq.pregunta}</span>
                  <svg class="faq-arrow w-5 h-5 shrink-0 text-secondary transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
                  </svg>
                </button>

                <div class="faq-outer">
                  <div class="px-6 pb-5 pt-2 text-gray-600 leading-relaxed border-t border-gray-100">
                    {faq.respuesta}
                  </div>
                </div>
              </div>
            ))
          }
        </div>
      </ScrollReveal>
    </div>
  </div>
</section>

<script>
  function initFaq() {
    var buttons = document.querySelectorAll(".faq-btn");
    var i;
    for (i = 0; i < buttons.length; i++) {
      (buttons[i] as HTMLButtonElement).addEventListener("click", faqClick);
    }
  }

  function faqClick(this: HTMLButtonElement) {
    var btn = this;
    var outer = btn.nextElementSibling as HTMLElement | null;
    var arrow = btn.querySelector(".faq-arrow") as HTMLElement | null;

    if (!outer || !arrow) return;

    var isOpen = btn.getAttribute("aria-expanded") === "true";

    if (isOpen) {
      outer.style.maxHeight = outer.scrollHeight + "px";
      requestAnimationFrame(function () {
        requestAnimationFrame(function () {
          outer!.style.maxHeight = "0px";
        });
      });
      btn.setAttribute("aria-expanded", "false");
      arrow.style.transform = "rotate(0deg)";
    } else {
      outer.style.maxHeight = outer.scrollHeight + "px";
      btn.setAttribute("aria-expanded", "true");
      arrow.style.transform = "rotate(180deg)";
    }
  }

  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initFaq);
  } else {
    initFaq();
  }
</script>

<style>
  .faq-outer {
    max-height: 0;
    overflow: hidden;
    transition: max-height 400ms ease;
  }
</style>
