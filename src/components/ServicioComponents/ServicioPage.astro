---
import Footer from "../Footer.astro";
import Header from "../Header.astro";
import ServiciosHero from "./ServiciosHero.astro";
import ServicioVentajas from "./ServicioVentajas.astro";
import ServicioFaq from "./ServicioFaq.astro";

interface FaqItem {
  pregunta: string;
  respuesta: string;
}

interface Props {
  title: string;
  description: string;
  ventajas: {
    titulo: string;
    descripcion: string;
    icono: string;
  }[];
  faqs?: FaqItem[];
}

const { title, description, ventajas, faqs = [] } = Astro.props;
---

<div id="container" class="flex flex-col min-h-screen">
  <Header />

  <main class="flex-1">
    <ServiciosHero title={title} description={description} />
    <ServicioVentajas ventajas={ventajas} />
    {faqs.length > 0 && <ServicioFaq faqs={faqs} />}
  </main>

  <Footer />
</div>
