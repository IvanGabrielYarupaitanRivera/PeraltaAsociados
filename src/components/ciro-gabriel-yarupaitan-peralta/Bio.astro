---
import BackgroundPattern from "@components/BackgroundPattern.astro";
import ScrollReveal from "@components/ScrollReveal.astro";

export interface Props {
  biografia: string;
  logros: string[];
  vision: string;
}

const { biografia, logros, vision } = Astro.props;
---

<section
  class="py-20 relative bg-neutral-100"
  aria-label="Perfil profesional de Ciro Gabriel Yarupaitan Peralta"
>
  <BackgroundPattern variant="subtle" opacity={0.3} />

  <div class="relative z-10 container mx-auto px-4  ">
    <!-- Perfil y Visión Jurídica -->
    <ScrollReveal animation="fade-up" delay={100}>
      <div class="flex items-center gap-4 mb-8">
        <div class="sm:block h-0.5 flex-1 bg-secondary" aria-hidden="true"></div>
        <p class="text-secondary font-medium tracking-wide uppercase text-sm whitespace-nowrap">
          Trayectoria y Principios
        </p>
        <div class="sm:block h-0.5 flex-1 bg-secondary" aria-hidden="true"></div>
      </div>

      <div class="text-center max-w-3xl mx-auto mb-12">
        <h2 class="font-serif text-3xl md:text-4xl text-primary font-bold mb-4">
          Perfil y Visión Jurídica
        </h2>
        <p class="text-gray-600">
          Trayectoria y principios que guían nuestro ejercicio profesional
        </p>
      </div>

      <div class="text-center max-w-2xl mx-auto">
        <p class="text-lg text-neutral-700 leading-relaxed text-pretty">
          {biografia}
        </p>
      </div>
    </ScrollReveal>

    <!-- Filosofía Profesional -->
    {vision && (
      <ScrollReveal animation="fade-up" delay={100}>
        <div class="my-16">
          <blockquote class="relative py-8 px-4 border-t border-b border-neutral-200 text-center">
            <span
              class="absolute top-2 left-1/2 -translate-x-1/2 text-5xl text-secondary/20 font-black pointer-events-none select-none"
              aria-hidden="true"
            >
              "
            </span>
            <p class="text-xl sm:text-2xl italic text-primary max-w-2xl mx-auto leading-normal">
              "{vision}"
            </p>
            <cite class="block mt-4 text-xs uppercase tracking-widest text-neutral-500 not-italic font-medium">
              — Filosofía Profesional del Despacho
            </cite>
          </blockquote>
        </div>
      </ScrollReveal>
    )}

    <!-- Casos de Éxito y Reconocimientos -->
    {logros.length > 0 && (
      <ScrollReveal animation="fade-up" delay={100}>
        <div class="flex items-center gap-4 mb-8">
          <div class="sm:block h-0.5 flex-1 bg-secondary" aria-hidden="true"></div>
          <p class="text-secondary font-medium tracking-wide uppercase text-sm whitespace-nowrap">
            Resultados que Respaldan
          </p>
          <div class="sm:block h-0.5 flex-1 bg-secondary" aria-hidden="true"></div>
        </div>

        <div class="text-center max-w-3xl mx-auto mb-12">
          <h3 class="font-serif text-2xl md:text-3xl text-primary font-bold mb-3">
            Casos de Éxito y Reconocimientos
          </h3>
        </div>

        <div class="divide-y divide-neutral-200 border-t border-b border-neutral-200 max-w-2xl mx-auto">
          {logros.map((logro, index) => (
            <div
              class="group py-6 flex flex-col md:flex-row md:items-start gap-4 md:gap-8 transition-colors duration-300 hover:bg-neutral-50/50 px-2"
            >
              <div class="text-xl font-bold text-secondary font-sans md:pt-1">
                {String(index + 1).padStart(2, "0")}
              </div>
              <div class="space-y-2 flex-1">
                <p class="text-base text-neutral-700 leading-relaxed text-pretty">
                  {logro}
                </p>
              </div>
            </div>
          ))}
        </div>
      </ScrollReveal>
    )}
  </div>
</section>
