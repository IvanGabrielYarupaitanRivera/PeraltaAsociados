---
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";
import { Icon } from "astro-icon/components";
import ScrollReveal from "@components/ScrollReveal.astro";
import BackgroundPattern from "@components/BackgroundPattern.astro";

export interface Props {
  nombre: string;
  titulo: string;
  foto?: ImageMetadata;
  colegiatura: string;
  experiencia: string;
  slogan: string;
}

const {
  nombre,
  titulo,
  foto,
  colegiatura,
  experiencia,
  slogan,
} = Astro.props;

const whatsappMessage =
  "Hola,%20deseo%20agendar%20una%20consulta%20legal%20directa%20con%20el%20Dr.%20Ciro%20Yarupaitan.";
const whatsappUrl = `https://wa.me/51976762237?text=${whatsappMessage}`;
---

<section
  class="relative overflow-hidden bg-linear-to-br from-blue-950 via-primary to-blue-900"
  aria-label="Ciro Gabriel Yarupaitan Peralta — Abogado Fundador"
>
  <BackgroundPattern variant="subtle" opacity={0.08} />

  <div class="relative z-10 container mx-auto px-4 py-16 md:py-24 lg:py-28">
    <div class="grid lg:grid-cols-2 gap-10 lg:gap-16 items-center max-w-6xl mx-auto">
      <!-- Columna: Foto -->
      <ScrollReveal animation="fade-up" delay={0}>
        <div class="flex justify-center lg:justify-end">
          <div class="relative w-72 sm:w-80 lg:w-96 aspect-3/4">
            {foto ? (
              <>
                <!-- Marco dorado decorativo -->
                <div
                  class="absolute -inset-3 border border-secondary/20 rounded-sm"
                  aria-hidden="true"
                ></div>
                <div
                  class="absolute -inset-1.5 border border-secondary/10 rounded-sm"
                  aria-hidden="true"
                ></div>

                <div class="relative rounded-sm overflow-hidden h-full ring-1 ring-secondary/25 shadow-2xl">
                  <Picture
                    src={foto}
                    formats={["avif", "webp"]}
                    widths={[400, 640, 800]}
                    sizes="(max-width: 768px) 72vw, (max-width: 1024px) 40vw, 384px"
                    alt="Retrato profesional del abogado Ciro Yarupaitan Peralta en su despacho jurídico, rodeado de bibliografía especializada y un entorno que refleja experiencia, confianza y profesionalismo."
                    class="w-full h-full object-cover object-top"
                    loading="eager"
                    decoding="async"
                    fetchpriority="high"
                    width={384}
                    height={512}
                    pictureAttributes={{
                      class: "w-full h-full",
                    }}
                  />
                </div>
              </>
            ) : (
              <div
                class="w-full h-full bg-primary/40 rounded-sm ring-1 ring-secondary/25 flex items-center justify-center"
                aria-hidden="true"
              >
                <Icon
                  name="mdi:account-tie"
                  class="w-20 h-20 text-secondary/40"
                />
              </div>
            )}

            {/* Badge de colegiatura flotante sobre la foto */}
            {colegiatura && (
              <span
                class="absolute -bottom-2 sm:-bottom-3 -right-2 sm:-right-3 bg-secondary text-primary text-xs font-bold tracking-widest px-3 py-1.5 rounded-sm shadow-lg"
                aria-label={`Colegiatura: ${colegiatura}`}
              >
                {colegiatura}
              </span>
            )}
          </div>
        </div>
      </ScrollReveal>

      <!-- Columna: Texto -->
      <ScrollReveal animation="fade-up" delay={150}>
        <div class="text-center lg:text-left max-w-lg mx-auto lg:mx-0">

          {/* Badge: 30 AÑOS — el gancho de apertura */}
          <div class="inline-flex items-center gap-3 mb-6">
            <span class="h-px w-6 bg-secondary" aria-hidden="true"></span>
            <span class="text-secondary  tracking-[0.2em] uppercase text-sm">
              {experiencia}
            </span>
            <span class="h-px w-6 bg-secondary" aria-hidden="true"></span>
          </div>

          {/* H1: Nombre */}
          <h1 class="font-serif text-3xl sm:text-4xl lg:text-5xl text-white font-bold mb-5 text-balance leading-tight">
            {nombre}
          </h1>

          {/* Línea dorada extensible bajo el H1 */}
          <div class="h-px w-16 bg-secondary/40 mx-auto lg:mx-0 mb-6" aria-hidden="true"></div>

          {/* Título profesional */}
          <p class="text-secondary/90 text-lg sm:text-xl font-medium mb-4">
            {titulo}
          </p>

          {/* Slogan */}
          {slogan && (
            <p class="text-white/60 text-base mb-8 text-pretty max-w-md mx-auto lg:mx-0">
              {slogan}
            </p>
          )}

          {/* CTAs */}
          <div class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start">
            <a
              href={whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="group inline-flex items-center justify-center px-8 py-4 text-base font-semibold text-primary bg-secondary hover:bg-secondary/90 transition-colors duration-300 rounded-sm shadow-lg hover:shadow-xl"
              aria-label="Agendar consulta legal con el Dr. Ciro Yarupaitan por WhatsApp"
            >
              <Icon
                name="mdi:whatsapp"
                class="w-5 h-5 mr-2"
                aria-hidden="true"
              />
              Agendar Consulta
            </a>
            <a
              href="/contacto/"
              class="group inline-flex items-center justify-center px-8 py-4 text-base font-medium text-white border border-white/20 hover:border-white/50 hover:bg-white/5 transition-all duration-300 rounded-sm"
            >
              <Icon
                name="mdi:email"
                class="w-5 h-5 mr-2 transition-transform duration-300 group-hover:-translate-y-0.5"
                aria-hidden="true"
              />
              Escríbanos
            </a>
          </div>
        </div>
      </ScrollReveal>
    </div>
  </div>
</section>
