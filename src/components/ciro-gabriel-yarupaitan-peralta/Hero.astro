---
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";
import { Icon } from "astro-icon/components";
import ScrollReveal from "@components/ScrollReveal.astro";

export interface Props {
  nombre: string;
  titulo: string;
  foto?: ImageMetadata;
  colegiatura: string;
  experiencia: string;
  slogan: string;
}

const {
  nombre,
  titulo,
  foto,
  colegiatura,
  experiencia,
  slogan,
} = Astro.props;

const whatsappMessage =
  "Hola,%20deseo%20agendar%20una%20consulta%20legal%20directa%20con%20el%20Dr.%20Ciro%20Yarupaitan.";
const whatsappUrl = `https://wa.me/51976762237?text=${whatsappMessage}`;
---

<section
  class="relative overflow-hidden bg-linear-to-br from-blue-900 via-primary to-blue-900"
  aria-label="Ciro Gabriel Yarupaitan Peralta — Abogado Fundador"
>
  <div class="container mx-auto px-4 py-16 md:py-24 lg:py-32">
    <ScrollReveal animation="fade-up" delay={0}>
      <div
        class="grid lg:grid-cols-5 gap-8 lg:gap-12 items-center max-w-5xl mx-auto"
      >
        <!-- Columna foto -->
        <div class="lg:col-span-2 flex justify-center lg:justify-end">
          <div
            class="relative w-64 h-80 sm:w-72 sm:h-96 lg:w-80 lg:h-112 rounded-xl overflow-hidden shadow-2xl ring-2 ring-secondary/30"
          >
            {foto ? (
              <Picture
                src={foto}
                formats={["avif", "webp"]}
                widths={[400, 640]}
                sizes="(max-width: 768px) 100vw, 400px"
                alt="Ciro Gabriel Yarupaitan Peralta"
                class="w-full h-full object-cover object-top"
                loading="eager"
                decoding="async"
                width={400}
                height={500}
                pictureAttributes={{
                  class: "w-full h-full",
                }}
              />
            ) : (
              <div
                class="w-full h-full bg-primary/50 flex items-center justify-center"
                aria-hidden="true"
              >
                <Icon
                  name="mdi:account-tie"
                  class="w-20 h-20 text-secondary/50"
                />
              </div>
            )}
          </div>
        </div>

        <!-- Columna texto -->
        <div class="lg:col-span-3 text-center lg:text-left">
          <!-- Línea decorativa + experiencia -->
          <div class="flex items-center gap-4 mb-6 justify-center lg:justify-start">
            <span class="sm:block h-0.5 w-12 bg-secondary" aria-hidden="true"></span>
            <p
              class="text-secondary font-medium tracking-wide uppercase text-sm sm:text-base"
            >
              {experiencia}
            </p>
          </div>

          <!-- H1 — Estrictamente el nombre -->
          <h1
            class="font-serif text-3xl sm:text-4xl lg:text-5xl text-white font-bold mb-4 text-balance"
          >
            {nombre}
          </h1>

          <!-- Título profesional (NO en H1) -->
          <p
            class="text-secondary text-lg sm:text-xl font-medium mb-6"
          >
            {titulo}
          </p>

          <!-- Datos: colegiatura + slogan -->
          <div class="flex flex-wrap gap-4 mb-8 justify-center lg:justify-start">
            {colegiatura && (
              <span
                class="inline-flex items-center gap-2 text-white/80 text-sm bg-white/10 px-4 py-2 rounded-sm"
              >
                <Icon
                  name="mdi:shield-check"
                  class="w-4 h-4 text-secondary"
                  aria-hidden="true"
                />
                {colegiatura}
              </span>
            )}
            {slogan && (
              <span
                class="inline-flex items-center gap-2 text-white/80 text-sm bg-white/10 px-4 py-2 rounded-sm"
              >
                <Icon
                  name="mdi:star-four-points"
                  class="w-4 h-4 text-secondary"
                  aria-hidden="true"
                />
                {slogan}
              </span>
            )}
          </div>

          <!-- CTA principal -->
          <div
            class="flex flex-col sm:flex-row gap-4 justify-center lg:justify-start"
          >
            <a
              href={whatsappUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center px-8 py-4 text-lg font-medium text-primary bg-secondary hover:bg-white transition-all duration-300 rounded-sm group shadow-lg hover:shadow-xl"
              aria-label="Agendar consulta legal con el Dr. Ciro Yarupaitan por WhatsApp"
            >
              <Icon
                name="mdi:whatsapp"
                class="w-5 h-5 mr-2"
                aria-hidden="true"
              />
              Agendar Consulta
              <Icon
                name="mdi:arrow-right"
                class="w-5 h-5 ml-2 transform transition-transform duration-300 group-hover:translate-x-1"
                aria-hidden="true"
              />
            </a>
            <a
              href="/contacto/"
              class="inline-flex items-center px-8 py-4 text-lg font-medium text-white border border-white/30 hover:border-white/60 hover:bg-white/10 transition-all duration-300 rounded-sm group"
            >
              <Icon
                name="mdi:email"
                class="w-5 h-5 mr-2"
                aria-hidden="true"
              />
              Escríbanos
            </a>
          </div>
        </div>
      </div>
    </ScrollReveal>
  </div>
</section>
