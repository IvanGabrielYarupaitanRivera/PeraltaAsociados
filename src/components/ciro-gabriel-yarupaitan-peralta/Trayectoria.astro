---
import BackgroundPattern from "@components/BackgroundPattern.astro";
import ScrollReveal from "@components/ScrollReveal.astro";

export interface FormacionItem {
  titulo: string;
  institucion: string;
  anio: string;
}

export interface EspecialidadItem {
  nombre: string;
  descripcion: string;
  icono: string;
}

export interface Props {
  formacion: FormacionItem[];
  especialidades: EspecialidadItem[];
  membresias: string[];
}

const { formacion, especialidades, membresias } = Astro.props;
---

<section
  class="py-20 relative bg-neutral-100"
  aria-label="Trayectoria académica y especialidades del Dr. Yarupaitan"
>
  <BackgroundPattern variant="subtle" opacity={0.3} />

  <div class="relative z-10 container mx-auto px-4  ">
    <!-- Encabezado de sección -->
    <ScrollReveal animation="fade-up" delay={200}>
      <div class="flex items-center gap-4 mb-8">
        <div class="sm:block h-0.5 flex-1 bg-secondary"></div>
        <p
          class="text-secondary font-medium tracking-wide uppercase text-sm whitespace-nowrap"
        >
          Credenciales e Idoneidad
        </p>
        <div class="sm:block h-0.5 flex-1 bg-secondary"></div>
      </div>

      <div class="text-center max-w-3xl mx-auto mb-16">
        <h2 class="font-serif text-3xl md:text-4xl text-primary font-bold mb-4">
          Trayectoria Académica y Distinciones
        </h2>
        <p class="text-gray-600">
          Sólida formación universitaria y adscripción a los cuerpos colegiados oficiales
        </p>
      </div>
    </ScrollReveal>

    <!-- Grid 2 columnas: Formación + Membresías -->
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 max-w-3xl mx-auto">
      <!-- Formación Académica -->
      <ScrollReveal animation="fade-up" delay={200}>
        <div class="border-t border-neutral-200 pt-6">
          <h3 class="font-serif text-xl font-bold text-primary mb-8">
            Formación Académica
          </h3>

          <ol class="space-y-8 list-none" aria-label="Historial académico">
            {formacion.map((item) => (
              <li
                class="border-b border-neutral-100 pb-6 last:border-b-0 last:pb-0"
              >
                <article>
                  <p class="text-xs font-medium tracking-wider text-secondary uppercase mb-1">
                    {item.anio}
                  </p>
                  <p class="font-bold text-primary text-base">
                    {item.titulo}
                  </p>
                  <p class="text-sm text-neutral-600 mt-1">
                    {item.institucion}
                  </p>
                </article>
              </li>
            ))}
          </ol>
        </div>
      </ScrollReveal>

      <!-- Membresías Profesionales -->
      <ScrollReveal animation="fade-up" delay={200}>
        <div class="border-t border-neutral-200 pt-6">
          <h3 class="font-serif text-xl font-bold text-primary mb-8">
            Membresías Profesionales
          </h3>

          <ul class="space-y-6 list-none" aria-label="Membresías profesionales">
            {membresias.map((membresia) => (
              <li
                class="flex items-start gap-3 border-b border-neutral-100 pb-5 last:border-b-0 last:pb-0"
              >
                <span class="text-secondary text-lg leading-none mt-0.5" aria-hidden="true">›</span>
                <div>
                  <p class="text-primary font-medium">{membresia}</p>
                  <p class="text-xs uppercase tracking-wider text-neutral-500 mt-1">
                    Miembro Activo
                  </p>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </ScrollReveal>
    </div>

    <!-- Áreas de Práctica Especializada -->
    {especialidades.length > 0 && (
      <ScrollReveal animation="fade-up" delay={200}>
        <div class="mt-20">
          <div class="flex items-center gap-4 mb-8">
            <div class="sm:block h-0.5 flex-1 bg-secondary"></div>
            <p
              class="text-secondary font-medium tracking-wide uppercase text-sm whitespace-nowrap"
            >
              Materias de Cobertura Legal
            </p>
            <div class="sm:block h-0.5 flex-1 bg-secondary"></div>
          </div>

          <div class="text-center max-w-3xl mx-auto mb-12">
            <h3 class="font-serif text-2xl md:text-3xl text-primary font-bold mb-3">
              Áreas de Práctica Especializada
            </h3>
          </div>

          <ol class="grid sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-10 pt-8 border-t border-neutral-200 list-none" aria-label="Áreas de práctica especializada">
            {especialidades.map((esp, index) => {
              const romanNumerals = ["I", "II", "III", "IV"];
              return (
                <li class="space-y-3">
                  <article>
                    <span class="text-xs font-bold tracking-widest text-secondary block">
                      {romanNumerals[index]}. {esp.nombre.toUpperCase()}
                    </span>
                    <div class="h-px w-6 bg-neutral-300" aria-hidden="true"></div>
                    <p class="text-sm text-neutral-700 leading-relaxed text-pretty">
                      {esp.descripcion}
                    </p>
                  </article>
                </li>
              );
            })}
          </ol>
        </div>
      </ScrollReveal>
    )}
  </div>
</section>
