---
import BackgroundPattern from "@components/BackgroundPattern.astro";
import ScrollReveal from "@components/ScrollReveal.astro";

export interface FormacionItem {
  titulo: string;
  institucion: string;
  anio: string;
}

export interface EspecialidadItem {
  nombre: string;
  descripcion: string;
  icono: string;
}

export interface Props {
  formacion: FormacionItem[];
  especialidades: EspecialidadItem[];
  membresias: string[];
}

const { formacion, especialidades, membresias } = Astro.props;
---

<section
  class="py-20 relative bg-neutral-100"
  aria-label="Trayectoria académica y especialidades del Dr. Yarupaitan"
>
  <BackgroundPattern variant="subtle" opacity={0.3} />

  <div class="relative z-10 container mx-auto px-4  ">
    <!-- Encabezado de sección -->
    <ScrollReveal animation="fade-up" delay={200}>
      <div class="flex items-center gap-4 mb-8">
        <div class="sm:block h-0.5 flex-1 bg-secondary"></div>
        <p
          class="text-secondary font-medium tracking-wide uppercase text-sm whitespace-nowrap"
        >
          Credenciales e Idoneidad
        </p>
        <div class="sm:block h-0.5 flex-1 bg-secondary"></div>
      </div>

      <div class="text-center   mx-auto mb-16">
        <h2 class="font-serif text-3xl md:text-4xl text-primary font-bold mb-4">
          Trayectoria Académica y Distinciones
        </h2>
        <p class="text-gray-600">
          Sólida formación universitaria y adscripción a los cuerpos colegiados oficiales
        </p>
      </div>
    </ScrollReveal>

    <!-- Grid 2 columnas: Formación + Membresías -->
    <div class="grid lg:grid-cols-2 gap-12 lg:gap-16 max-w-4xl mx-auto">
      <!-- Formación Académica -->
      <ScrollReveal animation="fade-up" delay={200}>
        <div>
          <h3 class="font-serif text-xl font-bold text-primary mb-8">
            Formación Académica
          </h3>

          <ol class="list-none" aria-label="Historial académico">
            {formacion.map((item) => (
              <li
                class="group relative border-t border-neutral-200 py-5 first:border-t-0 first:pt-0 cursor-default"
              >
                {/* Línea de tinta extensible */}
                <div
                  class="absolute top-0 left-0 h-[1.5px] w-0 bg-secondary transition-all duration-500 ease-out group-hover:w-full"
                  aria-hidden="true"
                ></div>

                <article class="pt-2">
                  <p
                    class="text-xs font-medium tracking-wider text-secondary uppercase mb-1 transition-transform duration-300 group-hover:translate-x-1"
                  >
                    {item.anio}
                  </p>
                  <p
                    class="font-bold text-primary text-base transition-colors duration-300 group-hover:text-secondary"
                  >
                    {item.titulo}
                  </p>
                  <p class="text-sm text-neutral-600 mt-1">
                    {item.institucion}
                  </p>
                </article>
              </li>
            ))}
          </ol>
        </div>
      </ScrollReveal>

      <!-- Membresías Profesionales -->
      <ScrollReveal animation="fade-up" delay={200}>
        <div>
          <h3 class="font-serif text-xl font-bold text-primary mb-8">
            Membresías Profesionales
          </h3>

          <ul class="list-none" aria-label="Membresías profesionales">
            {membresias.map((membresia) => (
              <li
                class="group relative flex items-start gap-3 border-t border-neutral-200 py-5 first:border-t-0 first:pt-0 cursor-default"
              >
                {/* Línea de tinta extensible */}
                <div
                  class="absolute top-0 left-0 h-[1.5px] w-0 bg-secondary transition-all duration-500 ease-out group-hover:w-full"
                  aria-hidden="true"
                ></div>

                <span
                  class="text-secondary text-lg leading-none mt-0.5 transition-transform duration-300 group-hover:translate-x-1"
                  aria-hidden="true"
                >
                  ›
                </span>
                <div class="pt-2">
                  <p
                    class="text-primary font-medium transition-colors duration-300 group-hover:text-secondary"
                  >
                    {membresia}
                  </p>
                  <p class="text-xs uppercase tracking-wider text-neutral-500 mt-1">
                    Miembro Activo
                  </p>
                </div>
              </li>
            ))}
          </ul>
        </div>
      </ScrollReveal>
    </div>

    <!-- Áreas de Práctica Especializada -->
    {especialidades.length > 0 && (
      <ScrollReveal animation="fade-up" delay={200}>
        <div class="mt-20">
          <div class="flex items-center gap-4 mb-8">
            <div class="sm:block h-0.5 flex-1 bg-secondary"></div>
            <p
              class="text-secondary font-medium tracking-wide uppercase text-sm whitespace-nowrap"
            >
              Materias de Cobertura Legal
            </p>
            <div class="sm:block h-0.5 flex-1 bg-secondary"></div>
          </div>

          <div class="text-center max-w-3xl mx-auto mb-12">
            <h3 class="font-serif text-2xl md:text-3xl text-primary font-bold mb-3">
              Áreas de Práctica Especializada
            </h3>
          </div>

          <ol
            class="grid sm:grid-cols-2 lg:grid-cols-4 gap-x-8 gap-y-10 list-none"
            aria-label="Áreas de práctica especializada"
          >
            {especialidades.map((esp, index) => {
              const romanNumerals = ["I", "II", "III", "IV"];
              return (
                <li
                  class="group relative cursor-default"
                >
                  <article class="pt-2">
                    <span
                      class="text-xs font-bold tracking-widest text-secondary block transition-transform duration-300 group-hover:translate-x-1"
                    >
                      {romanNumerals[index]}. {esp.nombre.toUpperCase()}
                    </span>
                    {/* Línea de tinta extensible */}
                    <div
                      class="h-px w-6 bg-neutral-300 transition-all duration-500 ease-out group-hover:w-full group-hover:bg-secondary mt-2"
                      aria-hidden="true"
                    ></div>
                    <p
                      class="text-sm text-neutral-700 leading-relaxed text-pretty mt-3 transition-colors duration-300 group-hover:text-primary"
                    >
                      {esp.descripcion}
                    </p>
                  </article>
                </li>
              );
            })}
          </ol>
        </div>
      </ScrollReveal>
    )}
  </div>
</section>
