---
import BackgroundPattern from "./BackgroundPattern.astro";
import ScrollReveal from "./ScrollReveal.astro";
import ServicioCard from "./ServicioCard.astro";

import derechoAdministrativo from "@assets/images/servicios/derechoAdministrativo.webp";
import derechoCivil from "@assets/images/servicios/derechoCivil.webp";
import derechoLaboral from "@assets/images/servicios/derechoLaboral.webp";
import derechoConstitucional from "@assets/images/servicios/derechoConstitucional.webp";
---

<section class="py-20 relative bg-neutral-100" id="servicios" aria-label="Servicios legales">
  <BackgroundPattern variant="subtle" opacity={0.3} />

  <div class="relative z-10">
    <div class="container mx-auto px-4">
      <ScrollReveal animation="fade-up" delay={100}>
        <!-- Texto decorativo -->
        <div class="flex items-center gap-4 mb-8">
          <div class="sm:block h-0.5 flex-1 bg-secondary"></div>
          <p class="text-secondary font-medium tracking-wide uppercase text-sm whitespace-nowrap">
            Defendiendo sus derechos
          </p>
          <div class="sm:block h-0.5 flex-1 bg-secondary"></div>
        </div>

        <!-- Encabezado de sección -->
        <div class="text-center max-w-3xl mx-auto mb-16">
          <h2 class="font-serif text-3xl md:text-4xl text-primary font-bold mb-4">
            Nuestros Servicios Legales
          </h2>
          <p class="text-gray-600">
            Soluciones legales claras y efectivas para proteger sus derechos
          </p>
        </div>

        <!-- Grid de servicios -->
        <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-8">
          <ServicioCard
            imagen={derechoAdministrativo}
            alt="Asesoría legal en derecho administrativo en Huancavelica"
            titulo="Derecho Administrativo"
            descripcion="¿Problemas laborales o con entidades públicas? Te defendemos en sanciones, procesos disciplinarios y te guiamos en trámites gubernamentales de manera clara y efectiva."
            url="/derecho-administrativo/"
            ariaLabel="Ver más detalles sobre Derecho Administrativo"
          />

          <ServicioCard
            imagen={derechoCivil}
            alt="Asesoría legal en derecho civil en Huancavelica"
            titulo="Derecho Civil"
            descripcion="Te ayudamos con trámites de posesión de propiedades, pensión de alimentos y cumplimiento de acuerdos de conciliación. Soluciones efectivas para tus asuntos legales civiles."
            url="/derecho-civil/"
            ariaLabel="Ver más detalles sobre servicios de Derecho Civil"
          />

          <ServicioCard
            imagen={derechoLaboral}
            alt="Asesoría en derecho laboral en Huancavelica"
            titulo="Derecho Laboral"
            descripcion="¿Te despidieron injustamente o no te pagan tus beneficios? Te ayudamos a recuperar tu trabajo y obtener las compensaciones que te corresponden por ley."
            url="/derecho-laboral/"
            ariaLabel="Ver más detalles sobre servicios de Derecho Laboral"
          />

          <ServicioCard
            imagen={derechoConstitucional}
            alt="Asesoría en derecho constitucional en Huancavelica"
            titulo="Derecho Constitucional"
            descripcion="Te protegemos mediante acciones de amparo, habeas corpus y hacemos cumplir las sentencias judiciales a tu favor. Defendemos tus libertades y derechos constitucionales."
            url="/derecho-constitucional/"
            ariaLabel="Ver más detalles sobre servicios de Derecho Constitucional"
          />
        </div>
      </ScrollReveal>
    </div>
  </div>
</section>
