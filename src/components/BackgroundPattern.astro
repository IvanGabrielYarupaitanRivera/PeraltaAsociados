---
interface Props {
  /** Tipo de patrón: "subtle" (círculos + líneas) o "triangles" (triángulos) */
  variant?: "subtle" | "triangles";
  /** Opacidad del contenedor (0-1), ej: 0.3 */
  opacity?: number;
}

const { variant = "subtle", opacity } = Astro.props;
const opacityClass = opacity !== undefined ? `opacity-${Math.round(opacity * 100)}` : "";
---

<div class="absolute inset-0 {opacityClass}">
  <svg
    width="100%"
    height="100%"
    xmlns="http://www.w3.org/2000/svg"
    aria-hidden="true"
  >
    {
      variant === "subtle" ? (
        <>
          <pattern
            id="subtle-pattern"
            x="0"
            y="0"
            width="40"
            height="40"
            patternUnits="userSpaceOnUse"
          >
            <path
              d="M0 20h40M20 0v40"
              stroke="#171E60"
              stroke-width="0.5"
              stroke-opacity="0.2"
              fill="none"
            ></path>
            <circle cx="20" cy="20" r="1" fill="#171E60" fill-opacity="0.2"></circle>
          </pattern>
          <rect width="100%" height="100%" fill="url(#subtle-pattern)"></rect>
        </>
      ) : (
        <>
          <defs>
            <pattern
              id="triangle-pattern"
              x="0"
              y="0"
              width="40"
              height="40"
              patternUnits="userSpaceOnUse"
            >
              <polygon points="40,40 40,0 0,40" fill="#171e60" fill-opacity="0.02"></polygon>
            </pattern>
          </defs>
          <rect width="100%" height="100%" fill="url(#triangle-pattern)"></rect>
        </>
      )
    }
  </svg>
</div>
