---
import { Image } from "astro:assets";
import type { ImageMetadata } from "astro";
import { Icon } from "astro-icon/components";

export interface Props {
  /** Imagen local importada de assets */
  imagen: ImageMetadata;
  /** Texto alternativo */
  alt: string;
  /** Título del servicio */
  titulo: string;
  /** Descripción breve */
  descripcion: string;
  /** URL del detalle */
  url: string;
  /** Aria-label para el enlace */
  ariaLabel: string;
}

const { imagen, alt, titulo, descripcion, url, ariaLabel } = Astro.props;
---

<article class="relative h-150 group overflow-hidden rounded-sm">
  <Image
    src={imagen}
    alt={alt}
    class="absolute inset-0 w-full h-full object-cover transition-transform duration-500 group-hover:scale-110"
    widths={[240, 540, 720]}
    sizes="(max-width: 360px) 240px, (max-width: 720px) 540px, (max-width: 1600px) 720px"
    format="webp"
    loading="lazy"
    decoding="async"
  />

  <div class="absolute inset-0 bg-linear-to-t from-black via-black/50 to-transparent"></div>

  <footer class="absolute bottom-0 left-0 right-0 p-8 text-white bg-linear-to-t from-black via-black/50 to-transparent">
    <header class="space-y-3 mb-6">
      <h3 class="font-serif text-2xl font-bold">{titulo}</h3>
      <p class="text-neutral-200 text-pretty">{descripcion}</p>
    </header>

    <a
      href={url}
      class="inline-flex items-center px-8 py-2 text-sm bg-primary hover:bg-primary/90 text-white transition-all duration-300 rounded-sm group"
      aria-label={ariaLabel}
    >
      <span>Ver detalles</span>
      <Icon
        name="mdi:arrow-right"
        class="w-4 h-4 ml-2 transform transition-transform duration-300 group-hover:translate-x-1"
        aria-hidden="true"
      />
    </a>
  </footer>
</article>
