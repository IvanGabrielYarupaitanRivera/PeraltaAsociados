---
import "@styles/global.css";
import WhatsAppFloat from "@components/WhatsAppFloat.astro";

interface Props {
  title?: string;
  description?: string; 
  keywords?: string; 
  robots?: string;
  schema?: {
    name?: string;
    description?: string;  
  };
  ogUrl?: string;
  ogImage?: string;
}

const {
  title = "Peralta Asociados | Abogado en Huancavelica",
  description = "Abogado especializado en Huancavelica. Expertos en derecho laboral, civil y administrativo. Consulta gratuita con el Dr. Ciro Yarupaitan Peralta.", 
  keywords = "abogado huancavelica, asesoría legal, derecho civil, derecho laboral, derecho administrativo, derecho constitucional, servicios legales perú, peralta asociados perú", 
  robots = "index, follow",
  schema = {
    name: "Peralta Asociados",
    description: "Asesoría legal especializada en Huancavelica en derecho civil, administrativo, laboral, constitucional y más. Contamos con abogados expertos y comprometidos en brindar soluciones legales efectivas. ¡Contáctenos para una consulta!" 
  },
  ogUrl = "https://peraltaasociados.com/",
  ogImage = "/images/og-image.jpg",
} = Astro.props;

const canonicalPath = Astro.url.pathname.endsWith("/")
  ? Astro.url.pathname
  : Astro.url.pathname + "/";
const canonicalUrl = new URL(canonicalPath, "https://peraltaasociados.com")
  .href;

const schemaData = {
  "@context": "https://schema.org",
  "@type": "LawFirm",
  "@id": "https://peraltaasociados.com/#firm",
  "name": schema.name,
  "legalName": "Peralta Asociados Estudio Jurídico",
  "image": "/images/og-image.jpg",
  "logo": "/images/logo.png",
  "slogan": "Su defensa en buenas manos",
  "url": canonicalUrl,
  "description": schema.description,
  "knowsAbout": [
    "Derecho Civil",
    "Derecho Laboral",
    "Derecho Administrativo",
    "Derecho Constitucional",
    "Litigios Locales en Huancavelica"
  ],
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Servicios Legales en Huancavelica",
    "itemListElement": [
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Asesoría en Derecho Civil",
          "description": "Especialistas en prescripción adquisitiva, pensión de alimentos, conciliación extrajudicial y saneamiento de propiedades en la región de Huancavelica."
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Asesoría en Derecho Laboral",
          "description": "Defensa en casos de despido arbitrario, reposición laboral, cobro de beneficios sociales como CTS y gratificaciones, e indemnizaciones en Huancavelica."
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Asesoría en Derecho Administrativo",
          "description": "Procesos disciplinarios PNP, defensa ante SUNAFIL y SUNAT, recursos impugnativos y trámites administrativos ante entidades públicas en Huancavelica."
        }
      },
      {
        "@type": "Offer",
        "itemOffered": {
          "@type": "Service",
          "name": "Asesoría en Derecho Constitucional",
          "description": "Acciones de amparo, habeas corpus, acciones de cumplimiento y defensa de derechos fundamentales en la región de Huancavelica."
        }
      }
    ]
  },
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "Jr. Mayta Cápac N° 215",
    "addressLocality": "Huancavelica",
    "addressRegion": "Huancavelica",
    "postalCode": "09001",
    "addressCountry": "PE"
  },
 "geo": { 
    "@type": "GeoCoordinates",
    "latitude": "-12.783512104745357",
    "longitude": "-74.96969928675489"
  },
  "telephone": "+51976762237",
  "email": "cyarupaitanp@gmail.com",
  "priceRange": "$$",
  "areaServed": {
    "@type": "City",
    "name": "Huancavelica"
  },  
  "serviceArea": [  
        {"@type": "City", "name": "Huancavelica"},
        {"@type": "AdministrativeArea", "name": "Huancavelica Region"}
    ],
  "sameAs": [
    "https://www.facebook.com/PeraltaAsociadosPeru",
  ],
  "availableLanguage": ["Spanish"],
  "openingHours": ["Mo-Fr 08:00-20:00"],
  "founder": "Dr. Ciro Gabriel Yarupaitan Peralta",
  "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+51976762237",
        "email": "cyarupaitanp@gmail.com",
        "contactType": "Atención al cliente"
    },
};
---

<script type="application/ld+json" set:html={JSON.stringify(schemaData)} is:inline>
</script>

<html lang="es">
  <head>
    <meta
      name="google-site-verification"
      content="X9ZpfzQYW6XW9Qskd50SJe1JMEgTGkCHv7uQbQxxD1o"
    />

    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />

    <!-- Favicon para modo claro -->
    <link
      rel="icon"
      type="image/svg+xml"
      href="/favicon-light.svg"
      media="(prefers-color-scheme: light)"
    />

    <!-- Favicon para modo oscuro -->
    <link
      rel="icon"
      type="image/svg+xml"
      href="/favicon-dark.svg"
      media="(prefers-color-scheme: dark)"
    />

    <!-- SEO Básico -->
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={ogUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={ogUrl} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Local Business Meta Tags -->
    <meta name="city" content="Huancavelica" />
    <meta name="state" content="Huancavelica" />
    <meta name="country" content="Perú" />
    <meta name="zipcode" content="09001" />
    <meta name="target" content="Huancavelica, Perú" />
    <meta name="subject" content="Servicios Legales en Huancavelica" />

    <!-- Palabras clave -->
    <meta
      name="keywords"
      content={keywords}
    />

    <!-- Información adicional -->
    <meta name="author" content="Peralta Asociados" />
    <meta name="robots" content={robots} />
    <link rel="canonical" href={canonicalUrl} />

    <!-- Verificación Bing Webmaster Tools -->
    <meta name="msvalidate.01" content="212B24E9157CE54B8F464CB7B221FC64" />

    <!-- Analytics Umami (cookie-less, sin impacto en SEO) -->
    <script is:inline defer src="https://cloud.umami.is/script.js" data-website-id="2f65f9d8-da6e-4324-b309-777b8d8c2278"></script>

    <!-- Slot para inyecciones específicas de páginas hijas (schemas, metadatos extra) -->
    <slot name="head-extra" />

    <!-- Metadatos alternativos -->
    <link
      rel="alternate"
      href="https://peraltaasociados.com"
      hreflang="es-PE"
    />
    <meta name="geo.region" content="PE-HUV" />
    <meta name="geo.placename" content="Huancavelica" />
    <meta name="geo.position" content="-12.7869;-74.9731" />
    <meta name="ICBM" content="-12.7869, -74.9731" />
  </head>
  <body>
    <!-- Skip to main content -->
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-60 focus:px-4 focus:py-2 focus:bg-primary focus:text-white focus:rounded-sm focus:outline-none"
    >
      Saltar al contenido principal
    </a>

    <div id="main-content">
      <slot />
    </div>
    <WhatsAppFloat />
  </body>
</html>
