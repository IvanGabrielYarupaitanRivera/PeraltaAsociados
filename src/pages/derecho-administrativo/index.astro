---
import ServicioPage from "@components/ServicioComponents/ServicioPage.astro";
import Layout from "@layouts/Layout.astro";
import "../../styles/global.css";
---

<Layout
  title="Derecho Administrativo en Huancavelica | Peralta Asociados"
  description="Especialistas en derecho administrativo en Huancavelica. Expertos en procesos disciplinarios PNP, defensa SUNAFIL y recursos administrativos. Primera consulta gratuita."
  keywords="derecho administrativo huancavelica, abogado administrativo, procesos disciplinarios PNP, defensa SUNAFIL, recursos administrativos, trámites administrativos huancavelica"
  schema={{
    name: "Derecho Administrativo - Peralta Asociados",
    description:
      "Asesoría especializada en derecho administrativo: procesos disciplinarios, recursos impugnativos y defensa ante SUNAFIL/SUNAT en Huancavelica. 15 años de experiencia.",
  }}
>
  <ServicioPage
    title="Abogado Administrativo en Huancavelica"
    description="Defendemos sus derechos ante entidades públicas. Especialistas en procesos disciplinarios PNP y recursos administrativos. Consulta gratuita."
    contexto="Asesoramos a ciudadanos, empresas y personal policial en Huancavelica que enfrentan procedimientos administrativos ante entidades públicas como SUNAFIL, SUNAT, municipalidades y gobiernos regionales. Especialistas en procesos disciplinarios PNP, recursos impugnativos, defensa ante sanciones administrativas y gestión de trámites gubernamentales. Defendemos sus derechos con conocimiento profundo de la Ley del Procedimiento Administrativo General."
    ventajas={[
      {
        titulo: "Experiencia en Derecho Administrativo",
        descripcion:
          "15 años resolviendo procedimientos administrativos en Huancavelica con éxito",
        icono: "mdi:shield-check",
      },
      {
        titulo: "Defensa ante Entidades Públicas",
        descripcion:
          "Especialistas en recursos impugnativos ante SUNAFIL y SUNAT en Huancavelica",
        icono: "mdi:gavel",
      },
      {
        titulo: "Procesos Disciplinarios PNP",
        descripcion:
          "Asesoría especializada en defensa administrativa para personal policial",
        icono: "mdi:police-badge",
      },
      {
        titulo: "Trámites Administrativos",
        descripcion:
          "Gestión eficiente de sus procedimientos ante instituciones públicas",
        icono: "mdi:file-document-outline",
      },
      {
        titulo: "Atención Personalizada",
        descripcion:
          "Seguimiento detallado y comunicación constante sobre su caso",
        icono: "mdi:account-multiple",
      },
      {
        titulo: "Primera Consulta Sin Costo",
        descripcion:
          "Evaluación gratuita de su caso administrativo con opciones claras",
        icono: "mdi:hand-coin",
      },
    ]}
    faqs={[
      {
        pregunta: "¿Qué hago si recibo una sanción administrativa de SUNAFIL en mi empresa?",
        respuesta: "Lo primero es no ignorar la notificación. Tiene un plazo para presentar sus descargos o recursos impugnativos. En Peralta Asociados evaluamos la sanción y preparamos la defensa adecuada, ya sea mediante recurso de reconsideración o apelación ante la autoridad competente.",
      },
      {
        pregunta: "¿Cómo defiendo a un efectivo PNP en un proceso disciplinario?",
        respuesta: "Los procesos disciplinarios policiales requieren una defensa técnica especializada. Asesoramos al personal PNP desde la etapa de investigación preliminar, presentamos descargos, recurrimos sanciones y lo acompañamos en todo el proceso ante la inspectoría o el tribunal disciplinario.",
      },
      {
        pregunta: "¿Cuánto tiempo tengo para impugnar una resolución administrativa?",
        respuesta: "Depende del tipo de procedimiento, pero en la Ley del Procedimiento Administrativo General los plazos típicos son de 15 días hábiles para presentar recurso de reconsideración y 15 días hábiles para apelación. Es crucial actuar rápidamente para no perder el derecho a impugnar.",
      },
    ]}
  />
</Layout>
