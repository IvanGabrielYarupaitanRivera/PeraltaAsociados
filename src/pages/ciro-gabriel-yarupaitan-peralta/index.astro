const pageDescription =
  "Conoce al Dr. Ciro Gabriel Yarupaitan Peralta, abogado fundador de Peralta Asociados. 30 años de experiencia en gestión pública, Ejecutor Coactivo, Juez de Paz Letrado y asesor jurídico. Derecho Civil, Laboral, Administrativo y Constitucional en Huancavelica.";
const pageKeywords =
  "ciro gabriel yarupaitan peralta, abogado fundador huancavelica, peralta asociados fundador, abogado huancavelica, estudio jurídico huancavelica, C.A.H.147, ejecutor coactivo, juez de paz huancavelica, derecho constitucional huancavelica";

