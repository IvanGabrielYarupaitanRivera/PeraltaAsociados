---
import ServicioPage from "@components/ServicioComponents/ServicioPage.astro";
import Layout from "@layouts/Layout.astro";
import "../../styles/global.css";
---

<Layout
  title="Abogado Civil en Huancavelica | Prescripción Adquisitiva y Alimentos | Peralta Asociados"
  description="Abogado civil especialista en prescripción adquisitiva y pensión de alimentos en Huancavelica. Asesoría en conciliación extrajudicial y saneamiento legal. Primera consulta gratuita."
  keywords="abogado civil huancavelica, prescripción adquisitiva, pensión alimentos huancavelica, conciliación extrajudicial, título propiedad, saneamiento legal, demanda alimentos, conflictos civiles"
  schema={{
    name: "Derecho Civil - Peralta Asociados Huancavelica",
    description:
      "Expertos en derecho civil: prescripción adquisitiva, pensión de alimentos, conciliación extrajudicial y saneamiento legal en Huancavelica. 15 años resolviendo conflictos civiles con éxito.",
  }}
>
  <ServicioPage
    title="Abogado Civil en Huancavelica"
    description="Especialistas en prescripción adquisitiva y pensión de alimentos. Resolución efectiva de conflictos civiles mediante conciliación extrajudicial. Consulta gratuita con expertos en derecho civil."
    contexto="Asesoramos a ciudadanos y familias en Huancavelica que enfrentan problemas de titulación de tierras, contratos de compraventa de inmuebles, procesos de prescripción adquisitiva y saneamiento legal ante la Corte Superior de Justicia de Huancavelica, así como demandas de pensión de alimentos, conciliaciones extrajudiciales y ejecución de acuerdos conciliatorios. Nuestro despacho en Jr. Mayta Cápac N° 215 atiende de lunes a viernes para brindar soluciones claras y efectivas a cada caso civil."
    ventajas={[
      {
        titulo: "Experiencia en Derecho Civil",
        descripcion:
          "15 años resolviendo casos civiles en Huancavelica con éxito. Especialistas en prescripción adquisitiva y pensión de alimentos.",
        icono: "mdi:scale-balance",
      },
      {
        titulo: "Prescripción Adquisitiva",
        descripcion:
          "Asesoramiento experto en saneamiento legal y obtención de títulos de propiedad en Huancavelica.",
        icono: "mdi:home-outline",
      },
      {
        titulo: "Pensión de Alimentos",
        descripcion:
          "Gestión especializada en demandas de alimentos y defensa de derechos familiares en Huancavelica.",
        icono: "mdi:account-child-outline",
      },
      {
        titulo: "Conciliación Extrajudicial",
        descripcion:
          "Resolución efectiva de conflictos civiles mediante acuerdos conciliatorios y su ejecución legal.",
        icono: "mdi:handshake",
      },
      {
        titulo: "Atención Personalizada",
        descripcion:
          "Seguimiento detallado de su caso civil con comunicación constante y lenguaje claro.",
        icono: "mdi:account-multiple",
      },
      {
        titulo: "Primera Consulta Gratuita",
        descripcion:
          "Evaluación sin costo de su caso civil con opciones claras y asesoría profesional.",
        icono: "mdi:hand-coin",
      },
    ]}
    faqs={[
      {
        pregunta: "¿Cuánto tiempo tarda un proceso de prescripción adquisitiva en Huancavelica?",
        respuesta: "El tiempo varía según la complejidad del caso, pero generalmente un proceso de prescripción adquisitiva en la Corte Superior de Justicia de Huancavelica puede durar entre 6 meses y 2 años, dependiendo de si existen oposición de terceros y de la carga procesal del juzgado.",
      },
      {
        pregunta: "¿Qué documentos necesito para iniciar una demanda de pensión de alimentos?",
        respuesta: "Principalmente necesita: partida de nacimiento del menor beneficiario, DNI del demandante y del demandado, prueba de ingresos del demandado (boletas, recibos, declaración jurada), y cualquier documento que acredite los gastos del menor. En Peralta Asociados le guiamos en todo el proceso.",
      },
      {
        pregunta: "¿Es obligatorio intentar una conciliación extrajudicial antes de demandar?",
        respuesta: "Sí, en la mayoría de casos civiles en Perú, incluyendo alimentos, tenencia y obligación de dar suma de dinero, es requisito previo acudir a un Centro de Conciliación Extrajudicial antes de presentar la demanda ante el Poder Judicial. Nosotros gestionamos todo el proceso conciliatorio.",
      },
    ]}
  />
</Layout>
